# 钉钉配置
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_ACCESS_TOKEN=your_access_token

# 大模型配置
LLM_API_BASE_URL=https://api.example.com/v1
LLM_API_KEY=your_api_key
LLM_MODEL=gpt-4

# FastGPT 配置
FASTGPT_API_URL=https://api.fastgpt.in
FASTGPT_API_KEY=your_fastgpt_key
FASTGPT_DATASET_ID=your_dataset_id
FASTGPT_COLLECTION_ID=your_collection_id

# 同步配置
SYNC_HOUR=0
SYNC_MINUTE=0
SYNC_BATCH_SIZE=100
SYNC_MAX_MESSAGES=1000

# 应用配置
APP_MODE=production
LOG_LEVEL=INFO
